# Server
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# Identity
PERSONA_NAME="Kuldeep Sharma"
PERSONA_EMAIL="kuldeep@example.com"
RESUME_PATH=./data/resume.md
GITHUB_OWNER=
GITHUB_REPOS=
GITHUB_TOKEN=

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# RAG embeddings, optional but recommended for final submission.
# Groq is used for generation; OpenAI is used only for embeddings because Groq does not provide embedding models.
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Booking: choose calcom or google
CALENDAR_PROVIDER=calcom
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_TIMEZONE=Asia/Kolkata
# Also supported: CAL_API_KEY, CAL_EVENT_TYPE_ID, CAL_TIMEZONE

# Voice provider webhook shared secret, if configured
VOICE_WEBHOOK_SECRET=
